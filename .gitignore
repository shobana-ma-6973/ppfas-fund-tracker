# Allow factsheet JSON files (needed for dashboard on Streamlit Cloud)
data/*.json
!data/sent_status.json
!data/factsheet_data.json
!data/factsheet_*.json
!data/allocation_history.json

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Secrets (NEVER commit!)
.env
*.env

# Temp files
*.tmp
*.pdf
